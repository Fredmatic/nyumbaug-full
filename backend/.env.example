# ── SERVER ──
PORT=5000
NODE_ENV=development

# ── DATABASE (PostgreSQL) ──
# Option A: Full connection string (Railway, Supabase, Render)
DATABASE_URL=postgresql://username:password@localhost:5432/nyumbaug

# Option B: Individual values (local PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nyumbaug
DB_USER=postgres
DB_PASSWORD=yourpassword

# ── JWT AUTH ──
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
JWT_EXPIRES_IN=7d

# ── CLOUDINARY (image uploads) ──
# Sign up free at cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── EMAIL (nodemailer) ──
# Use Gmail or any SMTP provider
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=fredhim90@gmail.com
EMAIL_PASS=ssaazif.5
EMAIL_FROM=NyumbaUG <fredhim90@gmail.com>

# ── FRONTEND URL (for CORS) ──
